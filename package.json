{
  "name": "worldcup2026-app",
  "version": "1.0.0",
  "description": "Live FIFA World Cup 2026 Dashboard - Fabric App powered by Rayfin",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:e2e": "playwright test --grep-invert @load && playwright test --grep @load --project=chromium --workers=1",
    "loadtest:local": "node loadtest/local-concurrency.mjs",
    "deploy": "npx rayfin up"
  },
  "keywords": [
    "worldcup",
    "fifa",
    "2026",
    "rayfin",
    "fabric"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16"
  }
}
